using namespace std;

struct file_info{
    const dpp::snowflake channel_id=0000000000000000000;
    string name; //Original file name/path
    string key; //XOR decryption key
    vector<uint64_t> msg_ids;
};

bool filecheck(const string &file_path);

//upload
void split(const string &path, const size_t &TEN_MB, file_info &upfile_info);
void encrypt(string &file_path, file_info &upfile_info);

//download
void disc_down(file_info &downfile_info, string path);
void decrypt(string path, string path_encrypted, file_info &downfile_info);

int main(){
    srand(time(nullptr)); //seed rand
    const size_t TEN_MB = 10 * 1024 * 1024; //max file upload size
    string act;
    string path;

    while (true){
        cout<<"Upload or download (u/d): ";
        getline(cin, act);
        transform(act.begin(), act.end(), act.begin(), ::tolower);
        if (act=="u" || act=="up" || act=="upload"){
            file_info upfile_info;
            while (true){ //loop until valid file path given
                cout<<"Path to file: ";
                getline(cin, path);

                if (filecheck(path)){
                    if (filecheck("discord_files.txt")){
                        ifstream disc_files_check("discord_files.txt");
                        if (!disc_files_check){
                            cout<<"Error reading discord_files.txt!\n";
                            exit(0);
                        }
    
                        //Get names of already uploaded files
                        string line;
                        bool save_next=false;
                        vector<string> file_names;
                        while (getline(disc_files_check, line)){
                            if (save_next){
                                file_names.push_back(line);
                            }
                            if (line.empty()){
                                save_next=true;
                            }
                            else{
                                save_next=false;
                            }
                        }
                        disc_files_check.close();
    
                        bool uploaded=false;
                        for (int i=0; i<file_names.size(); i++){ //check if file has already been uploaded and would cause naming conflicts if done again
                            if (path==file_names[i]){
                                cout<<"File already uploaded\n";
                                uploaded=true;
                            }
                        }
                        if (uploaded){
                            continue;
                        }
                    }

                    upfile_info.name=path;
                    encrypt(path, upfile_info);
                    split(path, TEN_MB, upfile_info); //split and upload

                    break;
                }//valid file path check
                cout<<"Invalid input!\n";
            }//file path loop

            //removes the encrypted version of the file after the upload is fully done
            string path_encrypted=path+"_encrypted";
            remove(path_encrypted.c_str());

            ofstream disc_files("discord_files.txt", ios::app); 
            if (!disc_files){
                cout<<"Error writing to discord_files.txt\n";
                exit(0);
            }

            disc_files<<endl; //blank space for reading later
            disc_files<<upfile_info.name<<endl;
            disc_files<<upfile_info.key<<endl;
            for (int i=upfile_info.msg_ids.size()-1; i>=0; i--){
                disc_files<<upfile_info.msg_ids[i]<<endl;
            }
            disc_files.close();
            
            //run the reading logic to attempt to verify the data before finishing
            try {
                string line;
                bool cont=false;
                bool after_key=false;
                vector<uint64_t> msg_ids_and_index;

                ifstream disc_files_check("discord_files.txt");
                if (!disc_files_check){
                    cout<<"Error reading discord_files.txt or uploads have not been made!\n";
                    exit(0);
                }

                while (getline(disc_files_check, line)){
                    if (line.empty() && after_key){
                        break;
                    }
                    if (cont){
                        msg_ids_and_index.push_back(stol(line));
                    }
                    if (line==upfile_info.key){
                        cont=true;
                        after_key=true;
                    }
                }

                if (msg_ids_and_index.size()==0){ //key determines when to start reading in msg ids
                    cout<<"Upload failed: key in discord_files.txt is corrupt!\n";
                    exit(0);
                }
                if (msg_ids_and_index.size()%2!=0){ //should be even as msg id and index always come as pairs
                    cout<<"Upload failed: message data in discord_files.txt is corrupt!\n";
                    exit(0);
                }

                //verify if msg id and file index number are properly ordered
                vector<uint64_t> sorted_msg_ids(msg_ids_and_index.size()/2);
                for (int i=0; i<msg_ids_and_index.size(); i++){
                    if (i%2==0){
                        if (msg_ids_and_index[i]<msg_ids_and_index[i+1]){
                            sorted_msg_ids[msg_ids_and_index[i]]=msg_ids_and_index[i+1];
                        }
                        else{
                            sorted_msg_ids[msg_ids_and_index[i+1]]=msg_ids_and_index[i];
                        }
                    }
                }
                for (int i=0; i<sorted_msg_ids.size(); i++){
                    if(sorted_msg_ids[i]<1000000000000000000){
                        cout<<"Upload failed: message data in discord_files.txt is corrupt!\n";
                        exit(0);
                    }
                }
            }//verification try
            catch(out_of_range& e){
                cout<<"Upload failed: message data in discord_files.txt is corrupt!\n";
                exit(0);
            }
            catch (invalid_argument& e){
                cout<<"Upload failed: message data in discord_files.txt is corrupt!\n";
                exit(0);
            }

            //may need to add logic to remove corrupt data from log file discord_files.txt

            cout<<"Upload successful\n";
            break;
        }//if upload
        else if (act=="d" || act=="down" || act=="download"){
            //initial read through to show the files uploaded and available for download
            ifstream disc_files_ini("discord_files.txt");
            if (!disc_files_ini){
                cout<<"Error reading discord_files.txt or uploads have not been made!\n";
                exit(0);
            }

            string line;
            bool save_next=false;
            bool get_key=false;
            vector<string> file_names;
            vector<string> keys;
            while (getline(disc_files_ini, line)){
                if (get_key){
                    keys.push_back(line);
                    get_key=false;
                }
                if (save_next){
                    file_names.push_back(line);
                    get_key=true;
                }
                if (line.empty()){
                    save_next=true;
                }
                else{
                    save_next=false;
                }
            }
            disc_files_ini.close();

            cout<<"*****Uploaded files*****\n";
            for (size_t i=0; i<file_names.size(); i++){
                cout<<i+1<<".  "<<file_names[i]<<'\n';
            }

            string str_num;
            int num;
            while (true){
                cout<<"File number to download: ";
                getline(cin, str_num);
                try{
                    num=stol(str_num);
                    break;
                }
                catch (invalid_argument& e){
                    cout<<"Invalid input!.\n";
                }
                catch (out_of_range& e){
                    cout << "Invalid input!\n";
                }
            }

            //secondary read through to populate msg ids and indexes
            ifstream disc_files_sec("discord_files.txt");
            if (!disc_files_sec){
                cout<<"Error reading discord_files.txt!\n";
                exit(0);
            }

            file_info downfile_info;
            downfile_info.name=file_names[num-1];
            downfile_info.key=keys[num-1];
            bool cont=false;
            bool after_key=false;
            vector<uint64_t> msg_ids_and_index;
            while (getline(disc_files_sec, line)){
                if (line.empty() && after_key){
                    break;
                }
                if (cont){
                    msg_ids_and_index.push_back(stol(line));
                }
                if (line==downfile_info.key){
                    cont=true;
                    after_key=true;
                }
            }
            disc_files_sec.close();

            vector<uint64_t> sorted_msg_ids(msg_ids_and_index.size()/2);
            for (int i=0; i<msg_ids_and_index.size(); i++){
                if (i%2==0){
                    if (msg_ids_and_index[i]<msg_ids_and_index[i+1]){
                        sorted_msg_ids[msg_ids_and_index[i]]=msg_ids_and_index[i+1];
                    }
                    else{
                        sorted_msg_ids[msg_ids_and_index[i+1]]=msg_ids_and_index[i];
                    }
                }
            }
            downfile_info.msg_ids=sorted_msg_ids;

            disc_down(downfile_info, downfile_info.name);
            
            break;
        }//if download
        else{
            cout<<"Invalid input!\n";
            continue;
        }
    }//validate act input loop
    return 0;
}

bool filecheck(const string &file_path){
    ifstream file_check(file_path);
    return file_check.good();
}

void encrypt(string &file_path ,file_info &upfile_info){
    //create key
    char key_element;
    string key;
    if (upfile_info.key.empty()){
        for (int i=0; i<30; i++){
            key_element=33+rand()%(126-33+1);
            key+=key_element;
        }
    }
    upfile_info.key=key;

    ifstream og(file_path, ios::binary);
    string encrypted_path=file_path+"_encrypted";
    ofstream encrypted(encrypted_path, ios::binary);
    if (!og){
        cout<<"Error opening file!\n";
        exit(0);
    }
    if (!encrypted){
        cout<<"Error creating encrypted file!\n";
        exit(0);
    }

    //XOR
    char buffer;
    size_t i = 0;
    while (og.get(buffer)) {
        buffer ^= key[i++ % key.size()];
        encrypted.put(buffer);
    }

    return;
}

void decrypt(string path, string path_encrypted, file_info &downfile_info){
    ifstream encrypted(path_encrypted, ios::binary);
    if (!encrypted){
        cout<<"Error opening "<<path_encrypted<<"!\n";
        exit(0);
    }

    string decrypted_path=path;
    //ensures if the file is still on disk its not overwritten
    if (filecheck(path)){ 
        decrypted_path=path+"_new";
    }

    ofstream decrypted(decrypted_path, ios::binary);
    if (!decrypted){
        cout<<"Error creating "<<decrypted_path<<"!\n";
        exit(0);
    }

    char buffer;
    size_t i=0;
    while (encrypted.get(buffer)) {
        buffer ^= downfile_info.key[i++ % downfile_info.key.size()];
        decrypted.put(buffer);
    }

    remove(path_encrypted.c_str());

    cout<<"Downloaded content at "<<decrypted_path<<'\n';

    return;
}

void split(const string &path, const size_t &TEN_MB, file_info &upfile_info){
    string up_root="discord_upload_";
    ifstream upfile(path+"_encrypted", ios::binary);

    if (!upfile){
        cout<<"Error opening "<<path+"_encrypted"<<" file!\n";
        exit(0);
    }

    upfile.seekg(0, ios::end);
    size_t size=upfile.tellg();
    upfile.seekg(0, ios::beg);

    int index=0;
    vector<string> temp_files;

    const char* token = getenv("DISCORD_TOKEN");
    if (!token) {
        cerr << "DISCORD_TOKEN environment variable not set\n";
        exit(0);
    }

    dpp::cluster bot(token);
    //bot.on_log(dpp::utility::cout_logger()); //for bot logs displayed in terminal

    mutex mtx;
    condition_variable cv;
    atomic<bool> uploaded{false};

    bot.on_ready([&bot, &mtx, &cv, &upfile_info, &uploaded, &index, TEN_MB, &size, &upfile, up_root, &temp_files](const dpp::ready_t& event) {
    while (size>0){ //loops until no data left
        //takes 10 MB chunk until last bit 
        size_t chunk_size=min(TEN_MB, size);
        vector<char> file_chunk(chunk_size);

        //reads from the encrypted file to be uploaded in 10 mb chucks to write to file_chunk
        upfile.read(file_chunk.data(), chunk_size);
        if (!upfile){
            cout<<"Error reading file!\n";
            exit(0);
        }

        //writes to a discord_upload_(index)
        string up_file=up_root+to_string(index);
        ofstream file_piece(up_file, ios::binary | ios::trunc);
        if (!file_piece){
            cout<<"Error opening discord_upload!\n";
            exit(0);
        }
        file_piece.write(file_chunk.data(), chunk_size);
        file_piece.close();
        temp_files.push_back(up_file);

        upfile_info.msg_ids.push_back(index); //adds a messages index to proceed it in msg_ids

        dpp::snowflake channel_id=upfile_info.channel_id; //set channel id to upload to

        //creates message with the file attached
        dpp::message msg(channel_id, "");
        msg.add_file(
            up_file,
            dpp::utility::read_file(up_file)
        );

        cout<<"Uploading: "<<up_file<<'\n';
        uploaded=false;//sets uploaded back to false on each iteration

        bot.message_create(
                msg,
                [&bot, &upfile_info, up_file, &index, &uploaded, &mtx, &cv](const dpp::confirmation_callback_t& callback) {
                    if (callback.is_error()){
                        cout<<"Failed to send message\n";
                        return;
                    }

                    //gets the message id
                    dpp::message sent = get<dpp::message>(callback.value);
                    cout<<"Uploaded: "<<up_file<<'\n';
                    dpp::snowflake message_id = sent.id;
                    upfile_info.msg_ids.push_back(message_id);

                    //Notify the main thread that upload finished
                    {
                        lock_guard<mutex> lock(mtx);
                        uploaded=true;
                    }
                    cv.notify_one();
                }
            );
        {
            //waits for uploaded to become true before letting the main thread continue
            unique_lock<mutex> lock(mtx);
            cv.wait(lock, [&]{ return uploaded.load(); });
        }
        index++;
        size-=chunk_size;
    }//while file has data
    bot.shutdown();
    });
    bot.start(dpp::st_wait);

    //removes the temp discord_upload_(index) files
    for (int i=0; i<temp_files.size(); i++){
        remove(temp_files[i].c_str());
    }

    return;
}

void disc_down(file_info &downfile_info, string path) {
    const dpp::snowflake channel_id=downfile_info.channel_id;

    //sets up output file to form the encrypted again
    string encrypted_file=path+"_encrypted_download";
    ofstream encrypted(encrypted_file, ios::binary | ios::app);
    if (!encrypted){
        cerr<<"Failed to open output file: "<<encrypted_file<<'\n';
        exit(0);
    }

    vector<string> temp_files;

    const char* token = getenv("DISCORD_TOKEN");
    if (!token){
        cout<<"DISCORD_TOKEN environment variable not set\n";
        exit(0);
    }

    dpp::cluster bot(token);
    //bot.on_log(dpp::utility::cout_logger()); //for bot logs
    bool cont;
    bot.on_ready([&bot, channel_id, &downfile_info, &encrypted, &cont, &temp_files](const dpp::ready_t&) {
    for (int i=0; i<downfile_info.msg_ids.size(); i++){
        cont=false;

        //finds the desired message to be downloaded
        dpp::snowflake message_id=downfile_info.msg_ids[i];
        bot.message_get(message_id, channel_id,
            [&bot, &encrypted, &downfile_info, i, &cont, &temp_files](const dpp::confirmation_callback_t& event) {

                auto msg=get<dpp::message>(event.value);
                auto attach = msg.attachments[0];
                string file_name=attach.filename; //bots retrieved file name
                string file_url=attach.url; //the url to download the file from

                cout<<"Downloading: "<<file_name<<" from "<<file_url<<'\n';

                //bot uses curl to fetch and download the proper file
                bot.request(file_url, dpp::m_get,
                    [file_name, &encrypted, &downfile_info, i, &cont, &temp_files](const dpp::http_request_completion_t& r) {
                        if (r.status == 200) {
                            ofstream out(file_name, ios::binary);
                            out << r.body;
                            out.close();
                            cout<<"Successfully downloaded "<<file_name<<'\n';

                            ifstream downloaded(file_name, ios::binary);
                            if (!downloaded){
                                cout<<"Error opening downloaded file: "<<file_name<<'\n';
                                exit(0);
                            }

                            encrypted<<downloaded.rdbuf(); //adds the just downloaded to the main file
                            downloaded.close();
                            temp_files.push_back(file_name);
                            cont=true;

                            //close the main file once the last index is retrieved then decrypts it
                            if (i==downfile_info.msg_ids.size()-1){ //uses the i index since the passed msg_ids from the struct are sorted in the processing done at the start
                                encrypted.close();
                                decrypt(downfile_info.name, downfile_info.name+"_encrypted_download", downfile_info);
                            }
                        } else {
                            cout<<"Download failed on "<<file_name<<'\n';
                            exit(0);
                        }
                    }
                );
            }
        );

        while(!cont){ //waits for file to be written to disk add appended to main file
            this_thread::sleep_for(chrono::milliseconds(100));
        }
    }
    bot.shutdown();
    });
    bot.start(dpp::st_wait);

    for (int i=0; i<temp_files.size(); i++){
        remove(temp_files[i].c_str());
    }

    return;
}
